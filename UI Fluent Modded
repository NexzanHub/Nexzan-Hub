    Keybind             = Color3.fromRGB(240, 240, 245),
    Input               = Color3.fromRGB(240, 240, 245),
    InputFocused        = Color3.fromRGB(255, 255, 255),
    InputIndicator      = Color3.fromRGB(200, 200, 210),
    InputIndicatorFocus = Color3.fromRGB(0, 150, 255),
    Dialog              = Color3.fromRGB(255, 255, 255),
    DialogHolder        = Color3.fromRGB(245, 245, 250),
    DialogHolderLine    = Color3.fromRGB(220, 220, 230),
    DialogButton        = Color3.fromRGB(235, 235, 242),
    DialogButtonBorder  = Color3.fromRGB(215, 215, 225),
    DialogBorder        = Color3.fromRGB(215, 215, 225),
    DialogInput         = Color3.fromRGB(240, 240, 245),
    DialogInputLine     = Color3.fromRGB(200, 200, 210),
    Text                = Color3.fromRGB(30, 30, 40), -- TEKS BERUBAH JADI HITAM/ABU TUA BIAR KELIHATAN
    SubText             = Color3.fromRGB(100, 100, 120),
