-- 2. SETUP WINDOW (Memakai tema "NexzanLight")
local Window = Fluent:CreateWindow({
    Title            = "Nexzan Hub",
    SubTitle         = "dev : Nexzan Hub",
    TabWidth         = 130,
    Size             = UDim2.fromOffset(460, 400),
    Acrylic          = false,
    Theme            = "NexzanLight", 
    MinimizeKey      = Enum.KeyCode.LeftControl,
    UserInfo         = true,
    UserInfoTop      = false,
    UserInfoTitle    = "Nexzan",
    UserInfoSubtitle = "Developer",
    UserInfoColor    = Color3.fromRGB(0, 150, 255),
    Search           = false,
})

-- 3. SETUP TABS & SECTIONS
local MainTab     = Window:AddTab({ Title = "Main",     Icon = "home" })
local SettingsTab = Window:AddTab({ Title = "Settings", Icon = "settings" })
local MainSection = MainTab:AddSection("Main Features")

-- 4. SETUP SETTINGS (Biar menu ganti warna muncul)
local SaveManager = Fluent.SaveManager
local InterfaceManager = Fluent.InterfaceManager
SaveManager:SetLibrary(Fluent)
InterfaceManager:SetLibrary(Fluent)
InterfaceManager:SetFolder("NexzanHub")
SaveManager:SetFolder("NexzanHub/Configs")

InterfaceManager:BuildInterfaceSection(SettingsTab)
SaveManager:BuildConfigSection(SettingsTab)

-- 5. RETURN AGAR BISA DISUNTIK FITUR DARI LUAR EXECUTOR
return {
    MainSection = MainSection,
    MainTab = MainTab,
    Window = Window,
    Fluent = Fluent
}
