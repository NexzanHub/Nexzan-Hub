local MainSection = MainTab:AddSection("Main Features")

-- 4. MINIMIZE BUTTON LINGKARAN KECIL (40x40) LOGO NH
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

if LocalPlayer:WaitForChild("PlayerGui"):FindFirstChild("NexzanMinimizeUI") then
    LocalPlayer.PlayerGui.NexzanMinimizeUI:Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "NexzanMinimizeUI"
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

local MinimizeBtn = Instance.new("ImageButton")
MinimizeBtn.Name = "MinimizeButton"
MinimizeBtn.Parent = ScreenGui
MinimizeBtn.Size = UDim2.fromOffset(40, 40)
MinimizeBtn.Position = UDim2.new(0.03, 0, 0.35, 0)
MinimizeBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
MinimizeBtn.BorderSizePixel = 0
MinimizeBtn.Active = true
MinimizeBtn.Draggable = true

Instance.new("UICorner", MinimizeBtn).CornerRadius = UDim.new(1, 0)
local UIStroke = Instance.new("UIStroke", MinimizeBtn)
UIStroke.Thickness = 2
UIStroke.Color = Color3.fromRGB(96, 205, 255)

local TextLabel = Instance.new("TextLabel", MinimizeBtn)
TextLabel.Size = UDim2.new(1, 0, 1, 0)
