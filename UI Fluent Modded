    TitleBarLine        = Color3.fromRGB(220, 220, 230),
    Tab                 = Color3.fromRGB(235, 235, 242),
    Element             = Color3.fromRGB(255, 255, 255), -- Kotak menu warna putih salju
    ElementBorder       = Color3.fromRGB(215, 215, 225),
    InElementBorder     = Color3.fromRGB(230, 230, 240),
    ElementTransparency = 0, -- Padat agar teks terlihat sangat jelas
    ToggleSlider        = Color3.fromRGB(210, 210, 220),
    ToggleToggled       = Color3.fromRGB(0, 150, 255),
    SliderRail          = Color3.fromRGB(210, 210, 220),
    DropdownFrame       = Color3.fromRGB(245, 245, 250),
    DropdownHolder      = Color3.fromRGB(255, 255, 255),
    DropdownBorder      = Color3.fromRGB(215, 215, 225),
