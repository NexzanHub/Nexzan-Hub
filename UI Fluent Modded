-- 2. CREATE WINDOW
local Window = Fluent:CreateWindow({
    Title            = "Nexzan Hub",
    SubTitle         = "dev : Nexzan Hub",
    TabWidth         = 130,
    Size             = UDim2.fromOffset(460, 400),
    Acrylic          = false,
